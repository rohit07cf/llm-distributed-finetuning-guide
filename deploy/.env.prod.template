# ─── Cloud Deployment Environment ───────────────────────────────────
# Copy this to deploy/.env.prod and fill in your values.
# deploy/.env.prod is git-ignored and will NOT be committed.

# Domain name pointing to this VM (e.g., llm.yourname.dev).
# Set to "localhost" for HTTP-only / IP-based access (no TLS).
DOMAIN=localhost

# Email for Let's Encrypt TLS certificates (required if DOMAIN != localhost).
ACME_EMAIL=

# Hugging Face model hub token (required for gated models like Llama).
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# Base model to load (default works for Llama 3 8B Instruct).
BASE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Path to LoRA/QLoRA adapter inside the container.
# Maps to ../outputs on host via volume mount.
ADAPTER_PATH=/app/outputs/lora_sft

# Quantization bits: 4 (QLoRA/NF4), 8 (int8), or 0 (full precision).
QUANTIZATION=4
